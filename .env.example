# Neon connection string (from the Neon dashboard, "Connection Details").
# Use the pooled connection string. Example:
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Secret used to sign login cookies. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Seed credentials created by `npm run initdb`. Change these.
ADMIN_USER=petch
ADMIN_PASS=change-me-admin
EXPERT_USER=expert
EXPERT_PASS=change-me-expert

# Local dev only: set to 'pg-shim' to use a local Postgres via node-postgres
# instead of Neon (see test/pgshim.mjs). Do NOT use in production.
# DATABASE_URL=pg-shim

NODE_ENV=development
PORT=3000
